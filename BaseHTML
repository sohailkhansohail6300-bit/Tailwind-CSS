{% load static %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fitness Club</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="w-full p-0 m-0">
    <header class="bg-gradient-to-b from-[#006285] to-[#00a5c6] text-white flex flex-col md:flex-row justify-between  gap-4 p-4">
        <div class="flex justify-between gap-auto">
        <h1 class="text-2xl font-bold md:3xl">Bilal Fitness Club</h1>
        <button class="md:hidden text-2xl gap-10" onclick="togglem()">☰</button>
        </div>
        <ul id='manue' class="hidden gap-full md:gap-4 md:flex md:flex-row   md:text-white">
            <a href='{% url "home" %}'><li class='hover:scale-105'>Home</li></a>
            <a href='{% url "services" %}'><li class='hover:scale-105'>Service</li></a>
            <a href='{% url "about" %}'><li class='hover:scale-105'>About</li></a>
            <a href='{% url "contact" %}'><li class='hover:scale-105'>Contact</li></a>
            <a href='{% url "login" %}'><li class='hover:scale-105 sm:ml-20 border bg-orange-500 text-white px-4 rounded-xl'>Login</li></a>
        </ul>
    </header>
  {% block base %}   {% endblock base %}

<footer class="w-full bg-gradient-to-b from-[#006285] to-[#00a5c6] text-white mt-10">
  <div class="max-w-7xl mx-auto px-3 py-3 lg:py-3">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">
      <div class="space-y-4">
        <h3 class="text-2xl font-bold tracking-tight">
          Fitness<span class="text-cyan-300">Pro</span>
        </h3>
        <p class="text-gray-200 leading-relaxed">
          Real coaching. Real results.<br>
          Personalized training & nutrition — online or in-person.
        </p>
        <div class="flex space-x-5 mt-4">
          <a href="#" class="text-white hover:text-cyan-200 transition text-xl">
            <i class="fab fa-instagram"></i>
          </a>
          <a href="#" class="text-white hover:text-cyan-200 transition text-xl">
            <i class="fab fa-facebook-f"></i>
          </a>
          <a href="#" class="text-white hover:text-cyan-200 transition text-xl">
            <i class="fab fa-youtube"></i>
          </a>
          <a href="#" class="text-white hover:text-cyan-200 transition text-xl">
            <i class="fab fa-whatsapp"></i>
          </a>
        </div>
      </div>
      <div class="space-y-4">
        <h4 class="text-xl font-semibold">Quick Links</h4>
        <ul class="space-y-3 text-gray-200">
          <li><a href="#" class="hover:text-cyan-200 transition">Home</a></li>
          <li><a href="#services" class="hover:text-cyan-200 transition">Services</a></li>
          <li><a href="#programs" class="hover:text-cyan-200 transition">Programs</a></li>
          <li><a href="#pricing" class="hover:text-cyan-200 transition">Pricing</a></li>
          <li><a href="#blog" class="hover:text-cyan-200 transition">Blog</a></li>
        </ul>
      </div>
      <div class="space-y-4">
        <h4 class="text-xl font-semibold">Support</h4>
        <ul class="space-y-3 text-gray-200">
          <li><a href="#" class="hover:text-cyan-200 transition">FAQ</a></li>
          <li><a href="#" class="hover:text-cyan-200 transition">How It Works</a></li>
          <li><a href="#" class="hover:text-cyan-200 transition">Contact Us</a></li>
          <li><a href="#" class="hover:text-cyan-200 transition">Privacy Policy</a></li>
          <li><a href="#" class="hover:text-cyan-200 transition">Terms of Service</a></li>
        </ul>
      </div>
      <div class="space-y-4">
        <h4 class="text-xl font-semibold">Contact</h4>
        <ul class="space-y-4 text-gray-200">
          <li class="flex items-start">
            <i class="fas fa-envelope mt-1 mr-3 text-cyan-300"></i>
            <span>hello@fitnesspro.com</span>
          </li>
          <li class="flex items-start">
            <i class="fas fa-phone mt-1 mr-3 text-cyan-300"></i>
            <span>+92 300 1234567</span>
          </li>
          <li class="flex items-start">
            <i class="fas fa-map-marker-alt mt-1 mr-3 text-cyan-300"></i>
            <span>Rawalpindi, Punjab, Pakistan</span>
          </li>
        </ul>
      </div>

    </div>
    <div class="mt-4 pt-2 border-t border-cyan-700/40 text-center text-sm text-gray-300">
      <p>© {{ 'now'|date:"Y" }} Fitness Pro. All rights reserved.</p>
      <p class="mt-2 text-gray-300">
        Built with dedication to help people live stronger, healthier lives.
      </p>
    </div>
  </div>
</footer>
     

    <script>
        function togglem(){
            document.getElementById('manue').classList.toggle('hidden');
        }
    </script>
</body>
</html>
